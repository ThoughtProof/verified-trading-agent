# Verified Trading Agent — configuration
#
# TWO wallets are needed for ERC-8004 reputation:
#   PRIVATE_KEY          = agent OWNER wallet (used once by scripts/register-agent.ts)
#   REPUTATION_PRIVATE_KEY = CLIENT wallet that writes feedback (used every cycle)
# The Reputation Registry enforces "Self-feedback not allowed" — the owner
# cannot write their own reputation. Feedback must come from a different address.

# Kimi K2.6 (Moonshot AI) — the REASONING agent. Global endpoint (.ai, NOT .cn).
# NOTE: kimi-k2.6 requires temperature=1 exactly. Reasoning model: output split
# into message.content (decision) + message.reasoning_content (the chain we verify).
MOONSHOT_API_KEY=sk-...

# ThoughtProof — the VERIFIER. Operator key (tp_op_...) from dashboard.thoughtproof.ai
THOUGHTPROOF_API_KEY=tp_op_...

# Agent OWNER wallet — used by scripts/register-agent.ts to register an ERC-8004
# agent on SKALE testnet. Throwaway testnet key only. Never a real-funds wallet.
PRIVATE_KEY=0x...

# CLIENT wallet — writes ERC-8004 giveFeedback (reputation signals) each cycle.
# Must be a DIFFERENT address than the agent owner. Throwaway testnet key only.
REPUTATION_PRIVATE_KEY=0x...

# ERC-8004 Agent ID on SKALE testnet (run: npx tsx scripts/register-agent.ts)
# Once registered, the agent's verdicts are written on-chain as reputation signals.
AGENT_ID=

# How many decision cycles per run when looping (0 = infinite)
MAX_CYCLES=0
# Seconds between cycles in loop mode
CYCLE_INTERVAL_SEC=900

# ── Active discovery (universe scan) ──────────────────────────────────────────
# Default ON. Each cycle scans the whole Binance USDT spot universe for relative
# strength + breakout structure (one cheap call), filters out illiquid pumps /
# stablecoins / leveraged tokens, ranks survivors, and rotates through the top-N
# strongest — what a real desk does. Set false to use the static SYMBOLS basket.
SCAN_ENABLED=true
# Minimum 24h USD volume to count as liquid (filters untradeable pumps).
SCAN_MIN_VOLUME_USD=10000000
# How many of the strongest candidates to rotate through.
SCAN_TOP_N=8

# Fallback / scan-off basket — the agent evaluates ONE symbol per cycle, rotating
# round-robin. Used when SCAN_ENABLED=false or a scan returns nothing.
# Legacy single-symbol var SYMBOL=BTCUSDT is still honored as a fallback.
SYMBOLS=BTCUSDT,ETHUSDT,SOLUSDT,BNBUSDT,XRPUSDT,DOGEUSDT

# ── DEX discovery (on-chain tail) ─────────────────────────────────────────────
# Default ON. Every DEX_EVERY_N-th cycle, probe trending on-chain pools via
# GeckoTerminal (free, no key) instead of a CEX symbol — the degen long-tail
# (thin liquidity, fresh pools, rugs) where outsized gains AND the real danger
# live. The agent gets hourly OHLCV (same technicals) plus on-chain risk context
# (liquidity, pool age); the liquidity/volume floors keep untradeable dust out.
DEX_ENABLED=true
# Probe a DEX token every Nth cycle (3 = roughly 1 in 3 cycles on-chain).
DEX_EVERY_N=3
# Liquidity / volume floors — below these a pool is an untradeable rug/dust risk.
DEX_MIN_LIQUIDITY_USD=250000
DEX_MIN_VOLUME_USD=500000
# How many of the strongest trending pools to rotate through.
DEX_TOP_N=6

# Polymarket crowd-intelligence enrichment (default OFF). Polymarket currently
# has no substantive BTC price-direction markets, so enabling this just logs
# "no relevant markets" every cycle. Turn on when relevant crypto markets exist
# or the agent trades Polymarket markets directly.
POLYMARKET_ENABLED=false
