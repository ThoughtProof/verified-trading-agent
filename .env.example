# Verified Trading Agent — configuration

# Kimi K2.6 (Moonshot AI) — the REASONING agent. Global endpoint (.ai, NOT .cn).
# NOTE: kimi-k2.6 requires temperature=1 exactly. Reasoning model: output split
# into message.content (decision) + message.reasoning_content (the chain we verify).
MOONSHOT_API_KEY=sk-...

# ThoughtProof — the VERIFIER. Operator key (tp_op_...) from dashboard.thoughtproof.ai
THOUGHTPROOF_API_KEY=tp_op_...

# SKALE testnet wallet — for ERC-8004 giveFeedback (on-chain reputation writes)
# This is the CLIENT wallet that writes feedback. Must NOT be the agent owner
# (contract enforces "Self-feedback not allowed"). Throwaway testnet key only.
REPUTATION_PRIVATE_KEY=0x...

# ERC-8004 Agent ID on SKALE testnet (run: npx tsx scripts/register-agent.ts)
# Once registered, the agent's verdicts are written on-chain as reputation signals.
AGENT_ID=571

# How many decision cycles per run when looping (0 = infinite)
MAX_CYCLES=0
# Seconds between cycles in loop mode
CYCLE_INTERVAL_SEC=900
